flowchart TD
  %% Paste vào draw.io: Insert -> Advanced -> Mermaid
  %% Lưu ý: Mermaid của draw.io thường KHÔNG hỗ trợ <br/> hoặc escape HTML.

  E([Entry])
  N1{{"N1: DK1 (diemTB < 0) OR (diemTB > 10)"}}
  A(["Exit A: Diem khong hop le"])

  N2{{"N2: DK2 (diemTB >= 8.5)"}}
  B(["Exit B: Gioi"])

  N3{{"N3: DK3 (diemTB >= 7.0)"}}
  C(["Exit C: Kha"])

  N4{{"N4: DK4 (diemTB >= 5.5)"}}
  D(["Exit D: Trung Binh"])

  N5{{"N5: DK5 (coThiLai)"}}
  ExE(["Exit E: Thi lai"])
  ExF(["Exit F: Yeu - Hoc lai"])

  E --> N1
  N1 -- True --> A
  N1 -- False --> N2
  N2 -- True --> B
  N2 -- False --> N3
  N3 -- True --> C
  N3 -- False --> N4
  N4 -- True --> D
  N4 -- False --> N5
  N5 -- True --> ExE
  N5 -- False --> ExF

  %% =========================
  %% Ý 2) Đường đi (Statement Coverage 100%) - TC tối thiểu
  %% TC1: diemTB=-1,  coThiLai=F  | Entry->N1(T)->ExitA
  %% TC2: diemTB=9,   coThiLai=F  | Entry->N1(F)->N2(T)->ExitB
  %% TC3: diemTB=7,   coThiLai=F  | Entry->N1(F)->N2(F)->N3(T)->ExitC
  %% TC4: diemTB=6,   coThiLai=F  | Entry->N1(F)->N2(F)->N3(F)->N4(T)->ExitD
  %% TC5: diemTB=5,   coThiLai=T  | Entry->N1(F)->N2(F)->N3(F)->N4(F)->N5(T)->ExitE
  %% TC6: diemTB=5,   coThiLai=F  | Entry->N1(F)->N2(F)->N3(F)->N4(F)->N5(F)->ExitF
  %% =========================

  %% =========================
  %% Ý 3) Branch Coverage 100% - nhánh nào được phủ bởi TC nào
  %% N1-True:  TC1
  %% N1-False: TC2, TC3, TC4, TC5, TC6
  %% N2-True:  TC2
  %% N2-False: TC3, TC4, TC5, TC6
  %% N3-True:  TC3
  %% N3-False: TC4, TC5, TC6
  %% N4-True:  TC4
  %% N4-False: TC5, TC6
  %% N5-True:  TC5
  %% N5-False: TC6
  %% =========================

