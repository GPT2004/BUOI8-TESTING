<html>
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
  <title>Bai 1.1 - Test cases</title>
  <style>
    table { border-collapse: collapse; font-family: Arial, sans-serif; }
    th, td { border: 1px solid #333; padding: 6px 8px; vertical-align: top; }
    th { background: #f2f2f2; }
    .small { color: #555; font-size: 12px; }
  </style>
</head>
<body>
<h3>Bài 1.1 - Test cases trang https://www.saucedemo.com/</h3>
<div class="small">
  File này là bảng HTML (.xls) mở được bằng Excel.
</div>
<table>
  <tr>
    <th>ID</th>
    <th>Title</th>
    <th>Objective</th>
    <th>Precondition</th>
    <th>Steps</th>
    <th>Test Data</th>
    <th>Expected Result</th>
    <th>Type</th>
    <th>Priority</th>
  </tr>

  <tr>
    <td>TC-01</td>
    <td>Verify homepage title</td>
    <td>Kiểm thử tiêu đề trang chủ</td>
    <td>Mở được Edge</td>
    <td>1) Open https://www.saucedemo.com/</td>
    <td>N/A</td>
    <td>Title = "Swag Labs"</td>
    <td>UI</td>
    <td>High</td>
  </tr>
  <tr>
    <td>TC-02</td>
    <td>Verify homepage URL</td>
    <td>Kiểm thử URL trang chủ</td>
    <td>Mở được Edge</td>
    <td>1) Open https://www.saucedemo.com/</td>
    <td>N/A</td>
    <td>URL contains "saucedemo"</td>
    <td>UI</td>
    <td>High</td>
  </tr>
  <tr>
    <td>TC-03</td>
    <td>Verify page source contains Swag Labs</td>
    <td>Kiểm thử page source</td>
    <td>Mở được Edge</td>
    <td>1) Open https://www.saucedemo.com/ 2) Get page source</td>
    <td>N/A</td>
    <td>Page source contains "Swag Labs"</td>
    <td>UI</td>
    <td>Medium</td>
  </tr>
  <tr>
    <td>TC-04</td>
    <td>Username input visible</td>
    <td>Kiểm thử form đăng nhập hiển thị</td>
    <td>Mở được Edge</td>
    <td>1) Open https://www.saucedemo.com/</td>
    <td>Locator: id=user-name</td>
    <td>Username input is displayed</td>
    <td>UI</td>
    <td>High</td>
  </tr>
  <tr>
    <td>TC-05</td>
    <td>Password input visible</td>
    <td>Kiểm thử form đăng nhập hiển thị</td>
    <td>Mở được Edge</td>
    <td>1) Open https://www.saucedemo.com/</td>
    <td>Locator: id=password</td>
    <td>Password input is displayed</td>
    <td>UI</td>
    <td>High</td>
  </tr>
  <tr>
    <td>TC-06</td>
    <td>Login button visible</td>
    <td>Kiểm thử form đăng nhập hiển thị</td>
    <td>Mở được Edge</td>
    <td>1) Open https://www.saucedemo.com/</td>
    <td>Locator: id=login-button</td>
    <td>Login button is displayed</td>
    <td>UI</td>
    <td>High</td>
  </tr>
  <tr>
    <td>TC-07</td>
    <td>Username placeholder text</td>
    <td>Kiểm tra placeholder của username</td>
    <td>Trang login mở</td>
    <td>1) Inspect username input attribute placeholder</td>
    <td>Expected placeholder: "Username"</td>
    <td>Placeholder đúng "Username"</td>
    <td>UI</td>
    <td>Low</td>
  </tr>
  <tr>
    <td>TC-08</td>
    <td>Password placeholder text</td>
    <td>Kiểm tra placeholder của password</td>
    <td>Trang login mở</td>
    <td>1) Inspect password input attribute placeholder</td>
    <td>Expected placeholder: "Password"</td>
    <td>Placeholder đúng "Password"</td>
    <td>UI</td>
    <td>Low</td>
  </tr>
  <tr>
    <td>TC-09</td>
    <td>Login button text</td>
    <td>Kiểm tra text nút login</td>
    <td>Trang login mở</td>
    <td>1) Check login button value/text</td>
    <td>Expected: "Login"</td>
    <td>Nút hiển thị "Login"</td>
    <td>UI</td>
    <td>Low</td>
  </tr>
  <tr>
    <td>TC-10</td>
    <td>Login form container exists</td>
    <td>Kiểm tra container của form</td>
    <td>Trang login mở</td>
    <td>1) Locate login container</td>
    <td>Locator: id=login_button_container</td>
    <td>Container tồn tại</td>
    <td>UI</td>
    <td>Medium</td>
  </tr>
  <tr>
    <td>TC-11</td>
    <td>Login with valid credentials</td>
    <td>Đăng nhập thành công</td>
    <td>Trang login mở</td>
    <td>1) Enter standard_user 2) Enter secret_sauce 3) Click Login</td>
    <td>standard_user / secret_sauce</td>
    <td>Navigate to /inventory.html</td>
    <td>Functional</td>
    <td>High</td>
  </tr>
  <tr>
    <td>TC-12</td>
    <td>Login with invalid password</td>
    <td>Đăng nhập sai mật khẩu</td>
    <td>Trang login mở</td>
    <td>1) Enter standard_user 2) Enter wrong 3) Click Login</td>
    <td>standard_user / wrong</td>
    <td>Error message displayed</td>
    <td>Functional</td>
    <td>High</td>
  </tr>
  <tr>
    <td>TC-13</td>
    <td>Login empty username</td>
    <td>Bỏ trống username</td>
    <td>Trang login mở</td>
    <td>1) Leave username empty 2) Enter secret_sauce 3) Click Login</td>
    <td>"" / secret_sauce</td>
    <td>Error contains "Username is required"</td>
    <td>Validation</td>
    <td>High</td>
  </tr>
  <tr>
    <td>TC-14</td>
    <td>Login empty password</td>
    <td>Bỏ trống password</td>
    <td>Trang login mở</td>
    <td>1) Enter standard_user 2) Leave password empty 3) Click Login</td>
    <td>standard_user / ""</td>
    <td>Error contains "Password is required"</td>
    <td>Validation</td>
    <td>High</td>
  </tr>
  <tr>
    <td>TC-15</td>
    <td>Login locked user</td>
    <td>Đăng nhập user bị khóa</td>
    <td>Trang login mở</td>
    <td>1) Enter locked_out_user 2) Enter secret_sauce 3) Click Login</td>
    <td>locked_out_user / secret_sauce</td>
    <td>Error contains "locked out"</td>
    <td>Functional</td>
    <td>High</td>
  </tr>
  <tr>
    <td>TC-16</td>
    <td>Error message dismiss button visible</td>
    <td>Kiểm tra nút đóng thông báo lỗi</td>
    <td>Sau khi login fail</td>
    <td>1) Cause error 2) Check dismiss button</td>
    <td>Locator: .error-button</td>
    <td>Nút đóng (X) hiển thị</td>
    <td>UI</td>
    <td>Medium</td>
  </tr>
  <tr>
    <td>TC-17</td>
    <td>Dismiss error message</td>
    <td>Đóng thông báo lỗi</td>
    <td>Sau khi login fail</td>
    <td>1) Click dismiss (X)</td>
    <td>N/A</td>
    <td>Error message disappears</td>
    <td>UI</td>
    <td>Medium</td>
  </tr>
  <tr>
    <td>TC-18</td>
    <td>Tab order username to password</td>
    <td>Kiểm tra tab order</td>
    <td>Trang login mở</td>
    <td>1) Focus username 2) Press TAB</td>
    <td>N/A</td>
    <td>Focus moves to password</td>
    <td>UX</td>
    <td>Low</td>
  </tr>
  <tr>
    <td>TC-19</td>
    <td>Enter key triggers login</td>
    <td>Kiểm tra Enter submit</td>
    <td>Trang login mở</td>
    <td>1) Fill username/password 2) Press ENTER</td>
    <td>standard_user / secret_sauce</td>
    <td>Login success (inventory)</td>
    <td>UX</td>
    <td>Low</td>
  </tr>
  <tr>
    <td>TC-20</td>
    <td>Page loads without console blocking</td>
    <td>Kiểm tra trang tải thành công</td>
    <td>Mạng ổn định</td>
    <td>1) Open homepage 2) Observe page content</td>
    <td>N/A</td>
    <td>Login page renders correctly</td>
    <td>Smoke</td>
    <td>Medium</td>
  </tr>
</table>
</body>
</html>

